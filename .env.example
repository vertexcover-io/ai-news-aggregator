# Database
DATABASE_URL=postgresql://newsletter:newsletter@localhost:5432/newsletter

# Redis
REDIS_URL=redis://localhost:6379

# Resend (email delivery)
RESEND_API_KEY=re_your_api_key_here

# Anthropic Claude (stage-2 reranker LLM + web collector extraction)
ANTHROPIC_API_KEY=
RANKING_MODEL=claude-haiku-4-5-20251001

# Voyage AI (stage-1 shortlist embeddings for personalized ranking)
VOYAGE_API_KEY=

# Jina (markdown fetching for web collector)
JINA_API_KEY=

# API
API_PORT=3000

# Absolute path to the directory containing user profile YAML files.
# Optional in dev (the API falls back to <repo-root>/profiles relative to
# the source file). Required in production / container deployments where
# process.cwd() and bundled file locations are not the source tree.
PROFILES_DIR=
