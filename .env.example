# Database
DATABASE_URL=postgresql://newsletter:newsletter@localhost:5433/newsletter

# Redis
REDIS_URL=redis://localhost:6379

# Resend (email delivery)
RESEND_API_KEY=re_your_api_key_here

# Admin gate (public archive listing — /admin/* is protected by a shared password)
ADMIN_PASSWORD=changeme-local-dev
# HMAC secret for the admin session cookie (32+ bytes; rotate to invalidate all sessions)
SESSION_SECRET=changeme-generate-with-openssl-rand-hex-32

# LLM providers
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# Gemini (LLM selector extraction for web-collect)
GEMINI_API_KEY=your-gemini-api-key-here
VOYAGE_API_KEY=your-voyage-api-key-here

# API
API_PORT=3000

# Auto-approve ranked items (skip manual review). Set to "true" to enable.
AUTO_REVIEW=false

# Web crawler concurrency (Crawlee AdaptivePlaywrightCrawler)
WEB_CRAWLER_CONCURRENCY=4

# Email provider: "resend" (default) or "ses"
EMAIL_PROVIDER=resend

# SES configuration (only required when EMAIL_PROVIDER=ses)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# Newsletter email settings
# SES_FROM_EMAIL must be a verified SES identity (domain or email).
SES_FROM_EMAIL=newsletter@mail.vertexcover.io
# NEWSLETTER_REPLY_TO_EMAIL should be a Google Group address with both
# team members (Aman + Ritesh) as members so replies fan out to both.
# See docs/spec/ver-85-newsletter-system/google-group-setup.md for setup.
NEWSLETTER_REPLY_TO_EMAIL=newsletter-feedback@vertexcover.io
NEWSLETTER_BASE_URL=https://newsletter.vertexcover.io

# Twitter/X collector — rettiwt-api user-auth key.
# Base64 of "auth_token=...; ct0=...; kdt=...; twid=...;" cookie pairs.
# Generate with the X Auth Helper browser extension, or by base64-encoding
# the cookie string from a logged-in browser session. Rotate by replacing
# the value (no code change required). Lasts up to 5 years if the source
# Twitter session isn't logged out.
RETTIWT_API_KEY=base64-of-twitter-cookie-string
