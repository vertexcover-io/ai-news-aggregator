# Database (host port must match compose.yml's postgres mapping)
DATABASE_URL=postgresql://newsletter:newsletter@localhost:5433/newsletter

# Redis
REDIS_URL=redis://localhost:6379

# Resend (email delivery)
RESEND_API_KEY=re_your_api_key_here

# Admin gate (public archive listing — /admin/* is protected by a shared password)
ADMIN_PASSWORD=changeme-local-dev
# HMAC secret for the admin session cookie (32+ bytes; rotate to invalidate all sessions)
SESSION_SECRET=changeme-generate-with-openssl-rand-hex-32

# LLM providers
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# DeepSeek API key — powers web-collector discovery + extraction (model: deepseek-v4-flash via @ai-sdk/deepseek)
DEEPSEEK_API_KEY=
VOYAGE_API_KEY=your-voyage-api-key-here

# API
API_PORT=3000

# Auto-approve ranked items (skip manual review). Set to "true" to enable.
AUTO_REVIEW=false

# Web crawler concurrency (Crawlee AdaptivePlaywrightCrawler)
WEB_CRAWLER_CONCURRENCY=4

# Optional HTTP proxy for the web collector. When set, sources blocked with a
# 403 on the direct (no-proxy) pass are retried through this proxy. Must be an
# HTTP(S) proxy with embedded credentials (Chromium can't authenticate SOCKS5),
# e.g. http://user:pass@p.webshare.io:80. Leave blank to disable the fallback.
# WEB_PROXY_URL=

# Email provider: "resend" (default) or "ses"
EMAIL_PROVIDER=resend

# SES configuration (only required when EMAIL_PROVIDER=ses)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# Newsletter email settings
# Maximum Resend API calls per second. Default: 3. Override with a positive integer.
EMAIL_SEND_RATE_PER_SECOND=3
# FROM_MAIL must be a verified sender for the chosen EMAIL_PROVIDER
# (Resend domain or SES identity).
FROM_MAIL=newsletter@news.vertexcover.io
# NEWSLETTER_REPLY_TO_EMAIL should be a Google Group address with both
# team members (Aman + Ritesh) as members so replies fan out to both.
# See docs/spec/ver-85-newsletter-system/google-group-setup.md for setup.
NEWSLETTER_REPLY_TO_EMAIL=newsletter-feedback@vertexcover.io
NEWSLETTER_BASE_URL=https://newsletter.vertexcover.io

# Twitter/X collector — rettiwt-api user-auth key.
# DEPRECATED: prefer managing this at /admin/settings (encrypted at rest in
# `social_credentials.twitter_collector`; takes effect on the next pipeline
# job without a worker restart). This env var remains as a fallback for
# bootstrap and prod deployments that haven't migrated yet.
#
# Base64 of "auth_token=...; ct0=...; kdt=...; twid=...;" cookie pairs.
# Generate with the X Auth Helper browser extension, or by base64-encoding
# the cookie string from a logged-in browser session. Rotate by replacing
# the value (or via /admin/settings — no code change required).
RETTIWT_API_KEY=base64-of-twitter-cookie-string

# Slack incoming webhook (notifications when an archive becomes reviewed).
# Posts a per-source telemetry summary to the configured channel on both
# manual review (PATCH /api/admin/archives/:runId) and AUTO_REVIEW pipeline
# completions. When unset/empty, notifications are disabled silently.
# Format: https://hooks.slack.com/services/T.../B.../...
SLACK_WEBHOOK_URL=

# Public base URL used to render archive links in the Slack message
# (e.g. https://newsletter.vertexcover.io). Optional; if unset, the message
# omits the link line.
PUBLIC_BASE_URL=

# PostHog analytics + error tracking fallback/bootstrap defaults. Admin
# settings are the source of truth after they are saved. This is the public
# project token, not a personal API key. When unset, all capture paths are
# silent no-ops (analytics, exceptions, and pipeline_run_degraded events).
POSTHOG_ENABLED=false
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com

# --- Error tracking → triage (optional; default OFF) ---
# When enabled, captured errors are classified, deduplicated by fingerprint into
# the error_incidents table, and routed: a Slack ping for every NEW incident
# (reuses SLACK_WEBHOOK_URL above) plus a GitHub issue for human/agent-fixable
# lanes. Leave unset/0 to keep capture-only (PostHog tagging still applies).
ERROR_TRACKING_ENABLED=0
# A transient (notify-lane) incident recurring this many times promotes to the
# human lane (re-pings Slack + opens an issue). Default 3.
ERROR_ESCALATION_THRESHOLD=3
# GitHub PAT (repo scope; + workflow scope for the Phase-2 auto-fix dispatch) and
# the target repo (owner/name). Required only for the GitHub-issue lane.
GITHUB_TOKEN=
GITHUB_REPO=vertexcover-io/ai-news-aggregator
# Phase 2 auto-fix lane: when enabled, an agent-fixable `schema` incident also fires
# a repository_dispatch (event_type error-autofix) that triggers the error-autofix.yml
# workflow to open a DRAFT fix PR. Requires GITHUB_TOKEN with `workflow` scope and the
# workflow present on the repo's DEFAULT branch. Leave 0 until classification is trusted.
ERROR_AUTOFIX_ENABLED=0

# --- Social posting (optional; if unset, social posts are disabled) ---
# Both credential sets below are also manageable at /admin/settings — values
# saved there are stored encrypted at rest in `social_credentials` and the
# pipeline resolves DB-first / env-fallback per job. These env keys remain
# the recommended bootstrap for first-time setup or CI; once admin has saved
# credentials via the settings page these env values are shadowed.

# LinkedIn personal profile posting (Share on LinkedIn product, w_member_social scope)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# LinkedIn API version pinned in the Authorization header. Bump quarterly before sunset.
LINKEDIN_API_VERSION=202511

# X / Twitter personal account posting (OAuth 1.0a user context; needs Read and write app permissions)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- Web-search collector (optional; collector skips gracefully when unset) ---
# Tavily Search API key — obtain at https://tavily.com
TAVILY_API_KEY=
