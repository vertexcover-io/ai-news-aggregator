{
  "name": "@newsletter/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest --project unit",
    "lint": "eslint ."
  },
  "dependencies": {
    "hono": "4.7.7",
    "@hono/node-server": "1.14.1",
    "@newsletter/pipeline": "workspace:*",
    "@newsletter/shared": "workspace:*",
    "bullmq": "5.51.0",
    "dotenv": "16.5.0",
    "drizzle-orm": "0.42.0",
    "ioredis": "5.6.1",
    "postgres": "3.4.7",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "@types/node": "22.15.3",
    "tsup": "8.4.0",
    "tsx": "4.19.4",
    "vitest": "3.2.1"
  }
}
