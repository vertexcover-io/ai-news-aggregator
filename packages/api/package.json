{
  "name": "@newsletter/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest --project unit",
    "lint": "eslint .",
    "bench:search": "tsx scripts/seed-search-perf.ts"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "3.1042.0",
    "@hono/node-server": "1.19.14",
    "@newsletter/pipeline": "workspace:*",
    "@newsletter/shared": "workspace:*",
    "@react-email/components": "1.0.12",
    "bullmq": "5.78.0",
    "dotenv": "16.5.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.23",
    "ioredis": "5.10.1",
    "postgres": "3.4.7",
    "posthog-node": "5.34.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "6.12.2",
    "rettiwt-api": "7.0.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/node-forge": "1.3.14",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "node-forge": "1.4.0",
    "tsup": "8.4.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.1"
  }
}
