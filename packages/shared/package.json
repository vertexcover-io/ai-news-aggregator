{
  "name": "@newsletter/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./db": "./dist/db/index.js",
    "./redis": "./dist/redis.js",
    "./types": "./dist/types/index.js",
    "./constants": "./dist/constants/index.js",
    "./utils": "./dist/utils/index.js",
    "./logger": "./dist/logger.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-orm": "0.42.0",
    "ioredis": "5.6.1",
    "pino": "9.6.0",
    "postgres": "3.4.7"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "bullmq": "5.51.0",
    "drizzle-kit": "0.31.1",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "vitest": "3.2.1"
  }
}
