{
  "name": "@newsletter/pipeline",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./add-post": "./dist/add-post-entry.js",
    "./eval": "./dist/eval-entry.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project seam --project crawler",
    "test:watch": "vitest --project unit",
    "eval:rank": "tsx src/scripts/evaluate-rank-prompt.ts",
    "eval:rank-run": "tsx src/scripts/evaluate-run-rank-prompt.ts",
    "eval:export-fixtures": "tsx src/scripts/eval-export-fixtures.ts",
    "eval:ranking": "tsx src/scripts/eval-ranking.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "2.0.74",
    "@ai-sdk/deepseek": "1.0.41",
    "@aws-sdk/client-sesv2": "3.1042.0",
    "@mozilla/readability": "0.6.0",
    "@newsletter/shared": "workspace:*",
    "@react-email/components": "1.0.12",
    "@tavily/core": "0.7.3",
    "ai": "5.0.169",
    "bullmq": "5.78.0",
    "posthog-node": "5.34.2",
    "chrono-node": "2.9.1",
    "crawlee": "3.13.3",
    "dotenv": "16.5.0",
    "drizzle-orm": "0.45.2",
    "ioredis": "5.10.1",
    "jsdom": "26.0.0",
    "p-limit": "7.3.0",
    "playwright-core": "1.52.0",
    "react": "19.2.4",
    "resend": "6.12.2",
    "rettiwt-api": "7.0.3",
    "turndown": "7.2.0",
    "turndown-plugin-gfm": "1.0.2",
    "twitter-api-v2": "1.29.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.7",
    "@types/node": "22.15.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/turndown": "5.0.5",
    "msw": "2.7.0",
    "postgres": "3.4.7",
    "tsup": "8.4.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.1"
  }
}
