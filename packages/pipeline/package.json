{
  "name": "@newsletter/pipeline",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./add-post": "./dist/add-post-entry.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project seam --project crawler",
    "test:watch": "vitest --project unit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "2.0.74",
    "@mozilla/readability": "0.6.0",
    "@newsletter/shared": "workspace:*",
    "agent-twitter-client": "0.0.18",
    "ai": "5.0.169",
    "bullmq": "5.51.0",
    "crawlee": "3.13.3",
    "dotenv": "16.5.0",
    "drizzle-orm": "0.42.0",
    "ioredis": "5.6.1",
    "jsdom": "26.0.0",
    "p-limit": "7.3.0",
    "playwright": "1.52.0",
    "turndown": "7.2.0",
    "turndown-plugin-gfm": "1.0.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "21.1.7",
    "@types/node": "22.15.3",
    "@types/turndown": "5.0.5",
    "postgres": "3.4.7",
    "tsup": "8.4.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.1"
  }
}
