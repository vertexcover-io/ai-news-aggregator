{
  "name": "@newsletter/eslint-plugin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@typescript-eslint/rule-tester": "8.58.0",
    "@typescript-eslint/utils": "8.58.0",
    "eslint": "10.1.0",
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "vitest": "3.2.1"
  }
}
