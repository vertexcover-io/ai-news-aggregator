{
  "name": "ai-newsletter",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "infra:up": "podman-compose up -d",
    "infra:down": "podman-compose down",
    "infra:reset": "podman-compose down -v && podman-compose up -d",
    "migrate:generate": "pnpm --filter @newsletter/shared db:generate",
    "migrate:up": "pnpm --filter @newsletter/shared db:migrate",
    "setup:local": "pnpm infra:up; pnpm migrate:up",
    "dev:extension": "pnpm setup:local && turbo dev --filter=@newsletter/api --filter=@newsletter/extension",
    "test:unit": "turbo test:unit",
    "test:e2e": "turbo test:e2e",
    "setup:ses": "tsx scripts/setup-ses.ts",
    "generate:llm-txt": "pnpm --filter @newsletter/api generate:llm-txt",
    "prepare": "husky"
  },
  "devDependencies": {
    "@aws-sdk/client-sesv2": "3.1042.0",
    "@aws-sdk/client-sns": "3.1042.0",
    "@eslint/js": "10.0.1",
    "tsx": "4.19.4",
    "@newsletter/eslint-plugin": "workspace:*",
    "@types/node": "22.15.3",
    "eslint": "10.1.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tsup": "8.4.0",
    "turbo": "2.5.4",
    "typescript": "5.8.3",
    "typescript-eslint": "8.58.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --no-warn-ignored --fix"
    ]
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "overrides": {
      "ws": "8.21.0",
      "engine.io": "6.6.8"
    }
  }
}
