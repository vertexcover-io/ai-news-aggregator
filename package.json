{
  "name": "ai-newsletter",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint && pnpm check:invariants",
    "check:invariants": "tsx tools/check-repo-invariants.ts",
    "infra:up": "podman-compose up -d",
    "infra:down": "podman-compose down",
    "infra:reset": "podman-compose down -v && podman-compose up -d",
    "test:unit": "turbo test:unit && pnpm test:tools",
    "test:tools": "vitest run --config=tools/vitest.config.ts",
    "test:e2e": "turbo test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@newsletter/eslint-plugin": "workspace:*",
    "@types/node": "22.15.3",
    "eslint": "10.1.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tsup": "8.4.0",
    "tsx": "4.20.3",
    "turbo": "2.5.4",
    "typescript": "5.8.3",
    "typescript-eslint": "8.58.0",
    "vitest": "3.2.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --no-warn-ignored --fix"
    ]
  },
  "packageManager": "pnpm@10.29.3"
}
