# Production environment variables.
# This file is the PLAINTEXT TEMPLATE. Do NOT commit it with real values.
# Workflow:
#   1. Copy this file: cp deployment/.env.prod.example deployment/.env.prod
#   2. Fill in real values in deployment/.env.prod
#   3. Encrypt:  sops --encrypt deployment/.env.prod > deployment/.env.prod.enc
#   4. rm deployment/.env.prod
#   5. Commit deployment/.env.prod.enc
#
# To edit an already-encrypted file: sops deployment/.env.prod.enc

# ─── Database ─────────────────────────────────────────────────────────────
# Points at the postgres container on the internal compose network.
DATABASE_URL=postgres://newsletter:REPLACE_ME@postgres:5432/newsletter
POSTGRES_USER=newsletter
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=newsletter

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Ranking / LLMs ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_ME
JINA_API_KEY=REPLACE_ME
RANKING_MODEL=claude-haiku-4-5-20251001

# ─── API ──────────────────────────────────────────────────────────────────
API_PORT=3000

# ─── GHCR (image pull auth) ───────────────────────────────────────────────
# PAT with read:packages scope. Used by deploy.sh for `docker login ghcr.io`.
GHCR_REPO_OWNER=vertexcover-io
GHCR_USERNAME=REPLACE_ME
GHCR_TOKEN=REPLACE_ME

# Admin session cookie HMAC secret (generated: openssl rand -hex 32)
SESSION_SECRET=REPLACE_ME
