# Production environment variables.
# This file is the source-of-truth TEMPLATE for GitHub Environment secrets.
# Do NOT commit it with real values.
# For production, create one GitHub Environment secret per key below under:
#   repo Settings → Environments → production → Secrets
# The deploy workflow renders these secrets into /etc/newsletter/.env on the VPS.

# ─── Database ─────────────────────────────────────────────────────────────
# Points at the postgres container on the internal compose network.
DATABASE_URL=postgres://newsletter:REPLACE_ME@postgres:5432/newsletter
POSTGRES_USER=newsletter
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=newsletter

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Ranking / LLMs ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_ME
# DeepSeek API key — web-collector discovery + extraction (deepseek-chat / V4 Flash)
DEEPSEEK_API_KEY=REPLACE_ME
JINA_API_KEY=REPLACE_ME
RANKING_MODEL=claude-haiku-4-5-20251001
# Concurrency cap for the web collector (default 4)
# WEB_CRAWLER_CONCURRENCY=4

# ─── Twitter collector (read-only scraper, NOT the same as auto-post X creds below) ─
RETTIWT_API_KEY=REPLACE_ME

# ─── Web search collector (Tavily) ───────────────────────────────────────
# Required when web_search_enabled=true in user_settings. Get an API key from
# https://app.tavily.com → API Keys. Collector logs a warning and skips when unset.
TAVILY_API_KEY=REPLACE_ME

# ─── Multi-tenant domains (host→tenant resolution) ────────────────────────
# REQUIRED on the multi-tenant build. Without ROOT_DOMAIN every `<slug>.<root>`
# request is classified "unknown" and 404s. See deployment/README.md →
# "Multi-tenant subdomains" for the matching wildcard DNS + TLS setup.
#
# ROOT_DOMAIN: apex under which tenant public sites live as `<slug>.<root>`.
ROOT_DOMAIN=agentloop.live
# APP_HOST: comma-separated host(s) for the admin/signup surface (tenant comes
# from the session, never the Host). Defaults to `app.<ROOT_DOMAIN>` if unset.
APP_HOST=app.agentloop.live
# CUSTOM_DOMAIN_MAP (optional): comma-separated `host=slug` pairs mapping a
# legacy/custom domain to a tenant slug — e.g. keep the existing single-tenant
# domain serving tenant 0 during the cutover. Leave blank to disable.
# CUSTOM_DOMAIN_MAP=agentloop.vertexcover.io=agentloop

# ─── API ──────────────────────────────────────────────────────────────────
API_PORT=3000
# Public base URL of the newsletter (used for archive permalinks in posts + email)
PUBLIC_BASE_URL=https://news.vertexcover.io
# Newsletter unsubscribe-link base URL (usually same as PUBLIC_BASE_URL)
NEWSLETTER_BASE_URL=https://news.vertexcover.io

# Admin login (shared password for /admin/*) — generate something strong
ADMIN_PASSWORD=REPLACE_ME
# Admin session cookie HMAC secret (generated: openssl rand -hex 32)
SESSION_SECRET=REPLACE_ME

# ─── Email delivery (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=REPLACE_ME
FROM_MAIL=newsletter@news.vertexcover.io
# Optional Reply-To header
NEWSLETTER_REPLY_TO_EMAIL=hello@vertexcover.com

# ─── Slack send-summary notification (optional; disabled when unset) ──────
SLACK_WEBHOOK_URL=

# ─── Auto-post: LinkedIn personal profile (optional; disabled when unset) ─
# Get Client ID/Secret from https://developer.linkedin.com → your app → Auth tab.
# Required app config: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect" products,
# redirect URI http://127.0.0.1:8765/callback. Run `pnpm tsx scripts/auth-linkedin.ts` once to seed
# the social_tokens table.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Pinned LinkedIn API version. Bump quarterly before sunset (LinkedIn sunsets ~12 months out).
LINKEDIN_API_VERSION=202511

# ─── Auto-post: X / Twitter personal account (optional; disabled when unset) ─
# Get OAuth 1.0a API Key/Secret plus Access Token/Secret from
# https://developer.x.com → your app → Keys and tokens. Required app config:
# App permissions = Read and write. Regenerate the access token/secret after
# changing permissions. Validate without posting via `pnpm tsx scripts/probe-twitter-oauth1.ts`.
# Account must be on Free tier OR have Pay-Per-Use credits topped up at
# developer.x.com → Billing.
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ─── Pipeline behavior ────────────────────────────────────────────────────
# When "true", a successful run is marked reviewed automatically (skips manual review gate).
# Leave unset/false in production.
# AUTO_REVIEW=false

# ─── GHCR (image pull auth) ───────────────────────────────────────────────
# PAT with read:packages scope. Used by deploy.sh for `docker login ghcr.io`.
GHCR_REPO_OWNER=vertexcover-io
GHCR_USERNAME=REPLACE_ME
GHCR_TOKEN=REPLACE_ME
